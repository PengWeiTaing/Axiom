{
  "identifier": "default",
  "description": "Default capability granting core and plugin permissions for the Axiom desktop app.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:5000/**" },
        { "url": "http://localhost:5000/**" }
      ]
    }
  ]
}
