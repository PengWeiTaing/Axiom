# Axiom receiver runtime config
# Use this as the template for /opt/axiom/.env on the VPS.

AXIOM_ROOT=/opt/axiom
AXIOM_ARCHIVE_PATH=/opt/axiom/data/archive
AXIOM_SECRET_KEY=change-me
AXIOM_HOST=0.0.0.0
AXIOM_PORT=5000
AXIOM_LOG_LEVEL=INFO
AXIOM_LOG_PATH=/opt/axiom/logs/receiver.log
AXIOM_MAX_UPLOAD_BYTES=20971520
AXIOM_AUDIO_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
AXIOM_AUDIO_TRANSCRIBE_LANGUAGE=zh
AXIOM_AUDIO_TRANSCRIBE_TIMEOUT_SECONDS=300
# AXIOM_OPENAI_API_KEY=
