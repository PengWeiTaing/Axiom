{
  "manifest_version": 3,
  "name": "Axiom 外脑",
  "version": "1.0",
  "description": "一键保存网页、想法到你的 Axiom 个人外脑系统",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": ["https://pengweitai.me/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "保存到 Axiom",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
