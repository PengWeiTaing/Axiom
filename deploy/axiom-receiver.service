[Unit]
Description=Axiom Flask receiver
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/axiom
EnvironmentFile=/opt/axiom/.env
ExecStart=/opt/axiom/.venv/bin/gunicorn --workers 1 --bind 127.0.0.1:5000 core.receiver:app
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
