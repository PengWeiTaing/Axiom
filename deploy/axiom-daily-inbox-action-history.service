[Unit]
Description=Axiom daily inbox action history snapshot

[Service]
Type=oneshot
WorkingDirectory=/opt/axiom
EnvironmentFile=/opt/axiom/.env
ExecStart=/opt/axiom/.venv/bin/python /opt/axiom/scripts/run_logged_automation.py --job-id inbox_action_history_day --root /opt/axiom --days-offset -1 --utc-offset +08:00
